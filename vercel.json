{
  "version": 2,
  "functions": {
    "*.php": {
      "runtime": "vercel-php@0.6.0"
    }
  },
  "routes": [
    { "src": "/", "dest": "/key.php" },
    { "src": "/auth.php", "dest": "/auth.php" },
    { "src": "/admin.php", "dest": "/admin.php" },
    { "src": "/(.*).php", "dest": "/$1.php" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
